# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FRIDAY OS — Environment Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in your values.
# Do NOT commit the .env file to version control.

# ── Application ──────────────────────
FRIDAY_APP_NAME=FRIDAY OS
FRIDAY_APP_VERSION=0.1.0
FRIDAY_ENV=development
FRIDAY_DEBUG=true
FRIDAY_LOG_LEVEL=DEBUG

# ── API Server ───────────────────────
FRIDAY_API_HOST=127.0.0.1
FRIDAY_API_PORT=8000
FRIDAY_API_WORKERS=1
FRIDAY_API_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Database ─────────────────────────
FRIDAY_DB_URL=sqlite+aiosqlite:///./data/friday.db
FRIDAY_DB_ECHO=false

# ── Security ─────────────────────────
FRIDAY_SECURITY_MODE=confirm
FRIDAY_SECRET_KEY=change-me-to-a-random-secret-key

# ── LLM (Ollama) ────────────────────
FRIDAY_OLLAMA_BASE_URL=http://localhost:11434
FRIDAY_OLLAMA_MODEL=llama3.1:8b
FRIDAY_OLLAMA_TIMEOUT=120

# ── Voice ────────────────────────────
FRIDAY_VOICE_WAKE_WORD=friday
FRIDAY_VOICE_STT_MODEL=base
FRIDAY_VOICE_TTS_VOICE=en-US-AriaNeural
FRIDAY_VOICE_LANGUAGE=en

# ── Paths ────────────────────────────
FRIDAY_DATA_DIR=./data
FRIDAY_LOGS_DIR=./data/logs
FRIDAY_ARTIFACTS_DIR=./data/artifacts
FRIDAY_CHROMA_DIR=./data/chroma
